# Copy to .env and fill in values before running credentialed smoke tests.
# Auth-gate tests (tests/smoke/auth-gate.spec.js) run with NO credentials.

# A Supabase athlete account for publish/messaging/recommendation tests.
TEST_ATHLETE_EMAIL=athlete@yourdomain.com
TEST_ATHLETE_PASSWORD=

# A Supabase college_coach account for recruiter board + messaging tests.
TEST_RECRUITER_EMAIL=recruiter@yourdomain.com
TEST_RECRUITER_PASSWORD=

# A Supabase hs_coach account for recommendation workflow tests.
TEST_HS_COACH_EMAIL=hscoach@yourdomain.com
TEST_HS_COACH_PASSWORD=

# A Supabase admin account for admin deactivate/preview tests.
TEST_ADMIN_EMAIL=admin@yourdomain.com
TEST_ADMIN_PASSWORD=

# UUID of a throwaway user to test deactivation (NOT a real user).
TEST_TARGET_USER_ID=

# UUID of a published athlete for preview tests.
TEST_ATHLETE_USER_ID=

# UUID of a live athlete on the recruiter board tests.
# Can be the same as TEST_ATHLETE_USER_ID.
# TEST_ATHLETE_USER_ID= (set above)

# A known-disabled Supabase account (is_active = false in user_profiles).
TEST_DISABLED_EMAIL=
TEST_DISABLED_PASSWORD=
